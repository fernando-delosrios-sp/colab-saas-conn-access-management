{
    "name": "access-management",
    "version": "0.1.2",
    "main": "dist/index.js",
    "scripts": {
        "test": "jest",
        "clean": "shx rm -rf ./dist",
        "prebuild": "npm run clean",
        "build": "npx ncc build ./src/index.ts -o ./dist -m -C",
        "dev": "cross-env NODE_OPTIONS=--enable-source-maps spcx run dist/index.js",
        "debug": "spcx run dist/index.js",
        "prettier": "npx prettier --write .",
        "prepack-zip": "npm ci && npm run build",
        "pack-zip": "spcx package"
    },
    "private": true,
    "dependencies": {
        "@sailpoint/connector-sdk": "^1.1.22",
        "axios-retry": "^4.5.0",
        "form-data": "^4.0.2",
        "sailpoint-api-client": "^1.6.0",
        "velocityjs": "^2.1.5"
    },
    "devDependencies": {
        "@types/jest": "^29.5.14",
        "@vercel/ncc": "^0.34.0",
        "cross-env": "7.0.3",
        "jest": "^29.7.0",
        "jest-util": "^30.4.1",
        "prettier": "^2.3.2",
        "shx": "^0.3.3",
        "ts-jest": "^29.4.11",
        "typescript": "^5.3.3",
        "typescript-eslint": "^8.2.0"
    },
    "prettier": {
        "printWidth": 120,
        "trailingComma": "es5",
        "tabWidth": 4,
        "semi": false,
        "singleQuote": true
    }
}
